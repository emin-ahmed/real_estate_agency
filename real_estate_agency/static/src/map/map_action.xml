<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="real_estate_agency.MapAction">
        <div class="o_re_map_action">
            <div t-if="state.error" class="o_re_map_error">
                <div class="alert alert-warning text-center mt-4 mx-auto" style="max-width:480px;">
                    <i class="fa fa-map-marker me-2"/>
                    <t t-esc="state.error"/>
                </div>
            </div>
            <t t-else="">
            <div class="o_re_sidebar">
                <div class="o_re_sidebar_header">
                    <h5 class="mb-0">Map</h5>
                    <span class="badge text-bg-primary">
                        <t t-esc="state.shownCount"/> / <t t-esc="state.totalCount"/> shown
                    </span>
                </div>

                <button class="btn btn-primary btn-sm w-100 mb-3" t-on-click="onNewPlot">
                    <i class="fa fa-plus me-1"/> New plot
                </button>

                <div class="o_re_filter_block">
                    <label class="o_re_filter_label">Status</label>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input"
                               id="re_f_available" t-model="state.filters.available"
                               t-on-change="onFilterChange"/>
                        <label class="form-check-label" for="re_f_available">
                            <span class="o_re_dot" style="background-color:#28a745;"/> Available
                        </label>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input"
                               id="re_f_reserved" t-model="state.filters.reserved"
                               t-on-change="onFilterChange"/>
                        <label class="form-check-label" for="re_f_reserved">
                            <span class="o_re_dot" style="background-color:#fd7e14;"/> Reserved
                        </label>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input"
                               id="re_f_sold" t-model="state.filters.sold"
                               t-on-change="onFilterChange"/>
                        <label class="form-check-label" for="re_f_sold">
                            <span class="o_re_dot" style="background-color:#dc3545;"/> Sold
                        </label>
                    </div>
                </div>

                <div class="o_re_filter_block">
                    <label class="o_re_filter_label" for="re_f_type">Property Type</label>
                    <select id="re_f_type" class="form-select form-select-sm"
                            t-model="state.filters.propertyType" t-on-change="onFilterChange">
                        <option value="">All types</option>
                        <option value="land">Land</option>
                        <option value="house">House</option>
                        <option value="duplex">Duplex</option>
                    </select>
                </div>

                <div class="o_re_filter_block">
                    <label class="o_re_filter_label" for="re_f_moughataa">Moughataa</label>
                    <select id="re_f_moughataa" class="form-select form-select-sm"
                            t-model="state.filters.moughataaId" t-on-change="onFilterChange">
                        <option value="">All moughataa</option>
                        <option t-foreach="state.moughataaOptions" t-as="m" t-key="m.id"
                                t-att-value="m.id" t-esc="m.name"/>
                    </select>
                </div>

                <div class="o_re_filter_block">
                    <label class="o_re_filter_label" for="re_f_lotissement">Lotissement</label>
                    <select id="re_f_lotissement" class="form-select form-select-sm"
                            t-model="state.filters.lotissementId" t-on-change="onFilterChange">
                        <option value="">All lotissements</option>
                        <option t-foreach="lotissementOptionsFiltered" t-as="lot" t-key="lot.id"
                                t-att-value="lot.id" t-esc="lot.name"/>
                    </select>
                </div>

                <div class="o_re_filter_block">
                    <label class="o_re_filter_label">Price (MRU)</label>
                    <div class="d-flex gap-1">
                        <input type="number" class="form-control form-control-sm" placeholder="Min"
                               t-model="state.filters.priceMin" t-on-change="onFilterChange"/>
                        <input type="number" class="form-control form-control-sm" placeholder="Max"
                               t-model="state.filters.priceMax" t-on-change="onFilterChange"/>
                    </div>
                </div>

                <div class="o_re_filter_block">
                    <label class="o_re_filter_label">Surface (m²)</label>
                    <div class="d-flex gap-1">
                        <input type="number" class="form-control form-control-sm" placeholder="Min"
                               t-model="state.filters.surfaceMin" t-on-change="onFilterChange"/>
                        <input type="number" class="form-control form-control-sm" placeholder="Max"
                               t-model="state.filters.surfaceMax" t-on-change="onFilterChange"/>
                    </div>
                </div>

                <button class="btn btn-outline-secondary btn-sm w-100 mt-2"
                        t-on-click="onResetFilters">
                    Reset filters
                </button>

                <p class="text-muted small mt-3 mb-0">
                    Tip: right-click the map to create a plot at that location.
                </p>
            </div>

            <div class="o_re_map" t-ref="map"/>
            </t>
        </div>
    </t>

    <t t-name="real_estate_agency.PlotPopup">
        <div class="o_re_popup">
            <div t-if="hasImages" class="o_re_carousel">
                <img class="o_re_popup_img" t-att-src="firstImg" alt="Plot photo"/>
                <t t-if="imgCount > 1">
                    <button type="button" class="o_re_nav o_re_prev" aria-label="Previous">&#8249;</button>
                    <button type="button" class="o_re_nav o_re_next" aria-label="Next">&#8250;</button>
                    <span class="o_re_counter">1 / <t t-esc="imgCount"/></span>
                </t>
            </div>
            <div class="o_re_popup_title">
                <strong t-esc="plot.reference"/>
                <span class="o_re_badge" t-attf-style="background-color:{{ stateColor }};"
                      t-esc="stateLabel"/>
            </div>
            <div t-if="typeLabel" class="text-muted small mb-1" t-esc="typeLabel"/>
            <table class="o_re_popup_table">
                <tr t-foreach="rows" t-as="r" t-key="r_index">
                    <td class="o_re_popup_k" t-esc="r.label"/>
                    <td class="o_re_popup_v" t-esc="r.value"/>
                </tr>
            </table>
            <button class="btn btn-sm btn-primary o_re_view_details mt-2" t-esc="viewDetails"/>
        </div>
    </t>

</templates>

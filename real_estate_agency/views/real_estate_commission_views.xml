<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Commission-focused list over sold plots. -->
    <record id="real_estate_commission_view_list" model="ir.ui.view">
        <field name="name">real.estate.plot.commission.list</field>
        <field name="model">real.estate.plot</field>
        <field name="arch" type="xml">
            <list string="Commissions" create="false" edit="false">
                <field name="sale_date"/>
                <field name="agent_id"/>
                <field name="buyer_id"/>
                <field name="reference"/>
                <field name="lotissement_id" optional="show"/>
                <field name="moughataa_id" optional="hide"/>
                <field name="sale_price" sum="Total sales"/>
                <field name="commission_type" optional="show"/>
                <field name="commission_rate" optional="hide"/>
                <field name="commission_total" sum="Total commission"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="real_estate_commission_view_search" model="ir.ui.view">
        <field name="name">real.estate.plot.commission.search</field>
        <field name="model">real.estate.plot</field>
        <field name="arch" type="xml">
            <search string="Commissions">
                <field name="agent_id"/>
                <field name="buyer_id"/>
                <field name="lotissement_id"/>
                <filter name="my_commissions" string="My Commissions"
                        domain="[('agent_id.user_ids', 'in', [uid])]"/>
                <separator/>
                <filter name="sale_this_month" string="Sold This Month"
                        domain="[('sale_date', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="sale_this_year" string="Sold This Year"
                        domain="[('sale_date', '&gt;=', (context_today() + relativedelta(month=1, day=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_sale_date" string="Sale Date"
                        date="sale_date"/>
                <group>
                    <filter name="group_agent" string="Agent"
                            context="{'group_by': 'agent_id'}"/>
                    <filter name="group_lotissement" string="Lotissement"
                            context="{'group_by': 'lotissement_id'}"/>
                    <filter name="group_sale_month" string="Sale Month"
                            context="{'group_by': 'sale_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="real_estate_commission_action" model="ir.actions.act_window">
        <field name="name">Commissions</field>
        <field name="res_model">real.estate.plot</field>
        <field name="view_mode">list</field>
        <field name="domain">[('state', '=', 'sold')]</field>
        <field name="view_id" ref="real_estate_commission_view_list"/>
        <field name="search_view_id" ref="real_estate_commission_view_search"/>
        <field name="context">{'search_default_group_agent': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No commissions yet
            </p>
            <p>
                Commissions appear here as plots are sold. Group by agent and
                filter by period to review who earned what.
            </p>
        </field>
    </record>

</odoo>

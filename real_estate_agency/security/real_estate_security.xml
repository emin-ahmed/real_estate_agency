<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

    <!--
        Odoo 19 security conventions: a res.groups links to a res.groups.privilege
        via `privilege_id`; the privilege carries the `category_id`. We define our
        own application category so the groups appear under "Real Estate" in
        Settings > Users.
    -->

    <record id="module_category_real_estate" model="ir.module.category">
        <field name="name">Real Estate</field>
        <field name="sequence">20</field>
    </record>

    <record id="res_groups_privilege_real_estate" model="res.groups.privilege">
        <field name="name">Real Estate</field>
        <field name="category_id" ref="module_category_real_estate"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_real_estate_user" model="res.groups">
        <field name="name">User</field>
        <field name="comment">Day-to-day use: manage plots, deals and own commissions.</field>
        <field name="privilege_id" ref="res_groups_privilege_real_estate"/>
    </record>

    <record id="group_real_estate_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="comment">Full access: configuration, all deals and commissions.</field>
        <field name="privilege_id" ref="res_groups_privilege_real_estate"/>
        <field name="implied_ids" eval="[(4, ref('group_real_estate_user'))]"/>
    </record>

    <!--
        Every administrator (Settings access) automatically becomes a Real Estate
        Manager, so the app is available to all admins out of the box. Odoo
        propagates this to existing members of the System group on upgrade.
    -->
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_real_estate_manager'))]"/>
    </record>

</data>
</odoo>

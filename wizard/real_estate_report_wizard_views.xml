<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= COMMISSION REPORT WIZARD =================== -->
    <record id="commission_report_wizard_view_form" model="ir.ui.view">
        <field name="name">real.estate.commission.report.wizard.form</field>
        <field name="model">real.estate.commission.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Commission Report">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="agent_id"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print" type="object" string="Print"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_commission_report_wizard" model="ir.actions.act_window">
        <field name="name">Commission Report</field>
        <field name="res_model">real.estate.commission.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ================== INVENTORY REPORT WIZARD =================== -->
    <record id="inventory_report_wizard_view_form" model="ir.ui.view">
        <field name="name">real.estate.inventory.report.wizard.form</field>
        <field name="model">real.estate.inventory.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Inventory Report">
                <group>
                    <field name="moughataa_id"/>
                    <field name="lotissement_id"/>
                </group>
                <footer>
                    <button name="action_print" type="object" string="Print"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_inventory_report_wizard" model="ir.actions.act_window">
        <field name="name">Inventory Report</field>
        <field name="res_model">real.estate.inventory.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ========================= MENUS ============================= -->
    <menuitem id="real_estate_menu_reporting"
              name="Reporting"
              parent="real_estate_menu_root"
              sequence="80"
              groups="group_real_estate_manager"/>

    <menuitem id="real_estate_menu_report_commission"
              name="Commission Report"
              parent="real_estate_menu_reporting"
              action="action_commission_report_wizard"
              sequence="10"/>

    <menuitem id="real_estate_menu_report_inventory"
              name="Inventory Report"
              parent="real_estate_menu_reporting"
              action="action_inventory_report_wizard"
              sequence="20"/>

</odoo>
